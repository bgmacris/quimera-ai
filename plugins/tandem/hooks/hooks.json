{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__.*tandem__browser_navigate",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/hook-inject-profile.mjs"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/chrome-daemon.sh stop"
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/hook-inject-profile.mjs cleanup"
          }
        ]
      }
    ]
  }
}
